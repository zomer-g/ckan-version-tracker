# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ckan_tracker

# Auth
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# CKAN Sources
DATA_GOV_IL_URL=https://data.gov.il
ODATA_URL=https://www.odata.org.il
ODATA_API_KEY=your-odata-api-key-here

# CORS (comma-separated origins, empty = allow all in dev)
CORS_ORIGINS=

# Polling
DEFAULT_POLL_INTERVAL=3600
MIN_POLL_INTERVAL=300
MAX_RESOURCE_DOWNLOAD_SIZE=524288000
