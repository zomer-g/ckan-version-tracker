# Database — Neon free tier (https://console.neon.tech)
# 1. Create a free project at neon.tech
# 2. Copy the connection string, change postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://user:pass@ep-example-123456.us-east-2.aws.neon.tech/ckan_tracker?sslmode=require

# Auth
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# CKAN Sources
DATA_GOV_IL_URL=https://data.gov.il
ODATA_URL=https://www.odata.org.il
ODATA_API_KEY=your-odata-api-key-here

# Object storage — independent file backend, decoupled from ODATA.
# STORAGE_BACKEND=odata (default) keeps the legacy CKAN-mirror behavior.
# Set STORAGE_BACKEND=r2 and fill the S3_* vars to archive files to an
# S3-compatible object store (Cloudflare R2 recommended: zero egress fees).
# Downloads are served directly from S3_PUBLIC_BASE_URL (a custom domain
# bound to the bucket), so file bytes never pass through this backend.
STORAGE_BACKEND=odata
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_PUBLIC_BASE_URL=

# CORS (comma-separated origins, empty = allow all in dev)
CORS_ORIGINS=

# App URL (used for OAuth redirect URIs)
APP_BASE_URL=http://localhost:8000

# SSO - Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Worker API key (for govil-scraper integration)
WORKER_API_KEY=

# Polling
DEFAULT_POLL_INTERVAL=3600
MIN_POLL_INTERVAL=300
MAX_RESOURCE_DOWNLOAD_SIZE=524288000
