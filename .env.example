# Database — Neon free tier (https://console.neon.tech)
# 1. Create a free project at neon.tech
# 2. Copy the connection string, change postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://user:pass@ep-example-123456.us-east-2.aws.neon.tech/ckan_tracker?sslmode=require

# Auth
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# CKAN Sources
DATA_GOV_IL_URL=https://data.gov.il
ODATA_URL=https://www.odata.org.il
ODATA_API_KEY=your-odata-api-key-here

# CORS (comma-separated origins, empty = allow all in dev)
CORS_ORIGINS=

# App URL (used for OAuth redirect URIs)
APP_BASE_URL=http://localhost:8000

# SSO - Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Polling
DEFAULT_POLL_INTERVAL=3600
MIN_POLL_INTERVAL=300
MAX_RESOURCE_DOWNLOAD_SIZE=524288000
